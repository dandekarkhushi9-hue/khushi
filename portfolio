  border-radius:12px;
  padding:10px;
  height:280px;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  transition:0.3s;
}

.cert-card:hover{
  transform:scale(1.03);
}

.cert-card img{
  width:100%;
  height:200px;
  object-fit:contain;
  background:white;
  border-radius:8px;
  padding:5px;
